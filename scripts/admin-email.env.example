# Copy to scripts/.env.admin.local (gitignored). Fill values. From repo root run:
#   npm run admin:update-user-email
#
# Get URL + service_role from Supabase → Project Settings → API.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Authentication → Users → User UID (the account whose email you are changing)
ADMIN_EMAIL_UPDATE_USER_ID=

# New login email
ADMIN_EMAIL_NEW_EMAIL=

# If true (default), also sets public.profiles.email for that user id
ADMIN_EMAIL_SYNC_PROFILES=true
